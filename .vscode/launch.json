{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Camara.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/CDIO/Camara.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${workspaceFolder}/.venv/Scripts/python.exe"
        },
        {
            "name": "Juego Mazmorra (consola externa)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Proyecto del juego/juego.exe",
            "args": [
                "start"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Proyecto del juego",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "preLaunchTask": "Build juego completo"
        },
        {
            "name": "C++: Archivo activo (consola externa)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "preLaunchTask": "C/C++: gcc.exe build active file"
        },
        {
            "type": "java",
            "name": "Launch Current Java File (Workspace JDK)",
            "request": "launch",
            "mainClass": "${fileBasenameNoExtension}",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build Java (javac)"
        },
        {
            "type": "java",
            "name": "Debug Evangelion",
            "request": "launch",
            "mainClass": "evangelion.Main",
            "cwd": "${workspaceFolder}/Evangelion",
            "console": "integratedTerminal",
            "preLaunchTask": "Build Evangelion (javac)",
            "classPaths": [
                "${workspaceFolder}/Evangelion/out/production/Evangelion"
            ],
            "sourcePaths": [
                "${workspaceFolder}/Evangelion/src"
            ]
        }
    ]
}