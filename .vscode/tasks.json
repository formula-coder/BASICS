{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Build juego completo",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "Proyecto del juego/main.cpp",
                "-o",
                "Proyecto del juego/juego.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Run Java (consola externa)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "start cmd /k \"cd /d ${fileDirname} && javac ${file} && java -cp ${fileDirname} ${fileBasenameNoExtension}\""
            ],
            "group": {
                "kind": "run",
                "isDefault": false
            }
        },
        {
            "label": "Run Camara.py (.venv)",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}\\CDIO\\Camara.py"
            ],
            "group": {
                "kind": "run",
                "isDefault": false
            }
        }
    ],
    "version": "2.0.0"
}