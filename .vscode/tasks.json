{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Build juego completo",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "Proyecto del juego/main.cpp",
                "-o",
                "Proyecto del juego/juego.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Run Java (consola externa)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "start cmd /k \"cd /d ${fileDirname} && \\\"C:\\\\Program Files\\\\Eclipse Adoptium\\\\jdk-25.0.3.9-hotspot\\\\bin\\\\javac.exe\\\" ${file} && \\\"C:\\\\Program Files\\\\Eclipse Adoptium\\\\jdk-25.0.3.9-hotspot\\\\bin\\\\java.exe\\\" -cp ${fileDirname} ${fileBasenameNoExtension}\""
            ],
            "group": {
                "kind": "run",
                "isDefault": false
            }
        },
        {
            "label": "Run Camara.py (.venv)",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}\\CDIO\\Camara.py"
            ],
            "group": {
                "kind": "run",
                "isDefault": false
            }
        }
        ,
        {
            "label": "Build Java (javac)",
            "type": "shell",
            "command": "C:\\Program Files\\Eclipse Adoptium\\jdk-25.0.3.9-hotspot\\bin\\javac.exe",
            "args": [
                "-g",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": "build",
            "problemMatcher": [
                "$javac"
            ]
        },
        {
            "label": "Build Evangelion (javac)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\build-evangelion.ps1"
            ],
            "group": "build",
            "problemMatcher": [
                "$javac"
            ]
        },
        {
            "label": "Run Evangelion (build + run)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\run-evangelion.ps1"
            ],
            "group": {
                "kind": "run",
                "isDefault": false
            }
        }
    ],
    "version": "2.0.0"
}